# ── Configuración del Blog Auditor ──────────────────────────────
# Copia este archivo a `.env` y completa los valores.
# NUNCA subas el archivo `.env` al repositorio.

# API key de OpenAI (OBLIGATORIA)
# Se crea en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Modelo a usar (opcional, default: gpt-5.4)
# Si el costo sube, se puede bajar a un modelo más económico (ej. gpt-5.3)
# sin tocar el código: solo cambia este valor.
OPENAI_MODEL=gpt-5.4

# Carpeta donde se guardan los reportes generados (opcional, default: reports)
REPORTS_DIR=reports
